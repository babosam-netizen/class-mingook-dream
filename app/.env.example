# Firebase 프로젝트 설정값 (Firebase Console > 프로젝트 설정 > 웹 앱에서 복사)
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_DATABASE_URL=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# 교사 인증 (Firebase Authentication에 등록한 계정과 동일하게)
VITE_TEACHER_EMAIL=teacher@mingook.app
VITE_TEACHER_PASSCODE=

# ── 링크/공유 (모두 선택) ─────────────────────────
# 이미지 업로드 서버는 필요 없습니다. (포스터·사법부 증거 모두 Canva 또는 이미지 주소 붙여넣기)
# 링크 미리보기 추출 주소. 비우면 같은 호스트 /fetch_meta.php → 실패 시 microlink로 자동 처리.
VITE_FETCH_META_URL=
# 공유/QR 링크에 쓸 앱 주소. 비우면 현재 배포 위치에서 자동 계산.
VITE_APP_URL=
